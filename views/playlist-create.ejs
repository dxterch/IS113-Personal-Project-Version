<!DOCTYPE html>
<html>
<head><title>Create Playlist</title></head>
<body>
    <nav>
        <a href="/auth/home/<%= uid %>">Homepage</a> | 
        <a href="/songs/search?uid=<%= uid %>">Search Songs</a>
    </nav>
    <hr>
    <h1>Create New Playlist</h1>

    <% if (error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <form action="/playlists/create" method="POST">
        <!-- Hidden input to pass the UID back to the controller -->
        <input type="hidden" name="uid" value="<%= uid %>">
        
        <label>Playlist Name:</label>
        <input type="text" name="playlistName" required>
        <br><br>
        <label>Description:</label>
        <textarea name="description"></textarea>
        <br><br>
        <button type="submit">Create Playlist</button>
    </form>
</body>
</html>