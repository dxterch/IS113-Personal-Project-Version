<!DOCTYPE html>
<html lang="en">

<head>
    <title>Homepage - Mini Spotify</title>
</head>

<body>
    <nav>
        <a href="/auth/home/<%= uid %>">Homepage</a> |
        <a href="/songs/search?uid=<%= uid %>">Search Songs</a> |
        <a href="/auth/logout">Logout</a>
    </nav>
    <hr>
    <!-- Personalized Greeting -->
    <h1>Welcome Back <%= username %>!</h1>

    <main>
        <!-- Playlists Section -->
        <section>
            <h2>Your Playlists: <a href="/playlists/create/<%= uid %>"><button type="button">+</button></a></h2>
            <form action="/playlists/delete" method="POST">
                <input type="hidden" name="uid" value="<%= uid %>"> <!-- Maintain Context -->
                <table border="1">
                    <thead>
                        <tr>
                            <th>Select</th>
                            <th>Name</th>
                            <th>Date Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (playlists.length> 0) { %>
                            <% playlists.forEach(playlist=> { %>
                                <tr>
                                    <td><input type="checkbox" name="selectedPlaylists" value="<%= playlist.PID %>">
                                    </td>
                                    <!-- Updated Link to Management Page -->
                                    <td><a href="/playlists/manage/<%= playlist.PID %>?uid=<%= uid %>">
                                            <%= playlist.PName %>
                                        </a></td>
                                    <td>
                                        <%= playlist.DateCreated %>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3">No playlists yet.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
                <br>
                <button type="submit">Delete Selected Playlists</button>
            </form>
        </section>

        <!-- Your Reviews Section -->
        <section>
            <h2>Your Reviews</h2>
            <form action="/reviews/delete" method="POST">
                <input type="hidden" name="uid" value="<%= uid %>">
                <table border="1">
                    <thead>
                        <tr>
                            <th>Select</th>
                            <th>Song</th>
                            <th>Artist</th>
                            <th>Rating</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% reviews.forEach(review=> { %>
                            <tr>
                                <td><input type="checkbox" name="selectedReviews" value="<%= review.RID %>"></td>
                                <td>
                                    <%= review.SongName %>
                                </td>
                                <td>
                                    <%= review.ArtistName %>
                                </td>
                                <td>
                                    <%= review.Rating %> / 5
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <br>
                <button type="submit">Delete Selected Reviews</button>
            </form>
        </section>
    </main>
</body>

</html>